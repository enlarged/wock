<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wock | Updates</title>
    <link rel="icon" type="image/png" id="favicon" href="/avatar.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/updates.css?v=20260331a" />
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a class="brand" href="/">
                <img id="brandAvatar" src="/avatar.png" alt="Wock" />
                <span>Wock</span>
            </a>

            <nav class="site-nav" aria-label="Main navigation">
                <a href="/">Home</a>
                <a href="/commands">Commands</a>
                <a href="/api">API</a>
                <a href="/docs">Docs</a>
                <a href="/status">Status</a>
                <a href="/updates" class="active">Updates</a>
                <a href="/gallery">Gallery</a>
            </nav>

            <div class="page-pill">
                <i class="fas fa-clock-rotate-left"></i>
                System Updates
            </div>
        </div>
    </header>

    <main class="updates-wrap">
        <section class="updates-hero">
            <h1>What’s New</h1>
            <p>Indexing deployment logs from channel 1482611787139649587</p>
        </section>

        <section class="timeline">
            <% if (typeof updates !== 'undefined' && updates.length > 0) { %>
                <% updates.forEach(update => { %>
                    <article class="update-entry">
                        <span class="update-date"><%= update.date %></span>
                        <div class="update-card">
                            <div class="update-content" data-markdown><%= update.content %></div>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="empty-log">
                    <i class="fas fa-terminal" style="font-size: 28px; margin-bottom: 14px;"></i>
                    <p>No logs detected in storage.</p>
                </div>
            <% } %>
        </section>
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <a href="/" class="footer-logo">
                    <img src="/avatar.png" alt="Wock" />
                    <span>Wock</span>
                </a>
                <p>The all-in-one Discord bot for moderation, utility, and more.</p>
            </div>

            <div class="footer-col">
                <h4>Support</h4>
                <a href="/docs">Documentation</a>
                <a href="https://discord.gg/wockbot" target="_blank" rel="noopener">Support Server</a>
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
            </div>

            <div class="footer-col">
                <h4>Community</h4>
                <div class="footer-socials">
                    <a href="https://discord.gg/wockbot" target="_blank" rel="noopener" aria-label="Discord"><i class="fab fa-discord"></i></a>
                    <a href="https://github.com/enlarged" target="_blank" rel="noopener" aria-label="GitHub"><i class="fab fa-github"></i></a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <span>© 2026 wock.best. All rights reserved.</span>
        </div>
    </footer>

    <script>
        document.querySelectorAll('[data-markdown]').forEach((el) => {
            el.innerHTML = marked.parse(el.textContent || '');
        });

        async function syncIcon() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if (data.avatar) {
                    document.getElementById('favicon').href = data.avatar;
                    const brandAvatar = document.getElementById('brandAvatar');
                    if (brandAvatar) brandAvatar.src = data.avatar;
                }
            } catch (_) {}
        }

        syncIcon();
    </script>
</body>
</html>