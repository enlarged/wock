<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= group.title %> | Wock Groups</title>
  <link rel="icon" type="image/png" id="favicon" href="/avatar.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    :root { --bg:#06070b; --border:rgba(255,255,255,.08); --text:#f1f3f8; --dim:#8a92a3; }
    * { box-sizing:border-box; }
    body { margin:0; font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,sans-serif; color:var(--text); background:radial-gradient(1600px 900px at 15% 0%, #0b1020 0%, var(--bg) 55%); }
    .wrap { max-width:1200px; margin:0 auto; padding:24px 18px 40px; }
    .hero { border:1px solid var(--border); border-radius:14px; padding:18px; background:linear-gradient(to bottom, rgba(14,18,30,.8), rgba(10,13,22,.72)); }
    .hero-head { display:flex; align-items:center; gap:10px; }
    .icon { width:34px; height:34px; border-radius:50%; object-fit:cover; border:1px solid var(--border); }
    .hero h1 { margin:0; font-size:34px; letter-spacing:-.03em; }
    .hero p { margin:8px 0 0; color:var(--dim); font-size:14px; }
    .hero img.banner { margin-top:12px; width:100%; max-height:220px; object-fit:cover; border-radius:10px; border:1px solid var(--border); }
    .grid { margin-top:12px; display:grid; gap:10px; grid-template-columns:repeat(auto-fill, minmax(280px,1fr)); }
    .card { text-decoration:none; color:inherit; border:1px solid var(--border); border-radius:12px; padding:12px; display:grid; grid-template-columns:46px minmax(0,1fr) auto; gap:10px; align-items:center; background:rgba(12,15,24,.92); }
    .card img { width:46px; height:46px; border-radius:50%; object-fit:cover; border:1px solid var(--border); }
    .meta { min-width:0; display:flex; flex-direction:column; }
    .uname { font-size:13px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .dname { font-size:12px; color:var(--dim); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .role { margin-top:4px; font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:#cfd8ff; }
    .views { color:var(--dim); font-size:12px; white-space:nowrap; }
    .back { display:inline-flex; margin-bottom:10px; align-items:center; gap:8px; color:var(--dim); text-decoration:none; font-size:13px; }
  </style>
</head>
<body>
  <div class="wrap">
    <a class="back" href="/profiles"><i class="fas fa-arrow-left"></i> Back to Profiles</a>
    <section class="hero">
      <div class="hero-head">
        <%- group.icon %>
        <h1><%= group.title %></h1>
      </div>
      <p><%= group.memberCount %> member(s) • created <%= group.createdLabel %></p>
      <%- group.banner %>
    </section>
    <section class="grid"><%- group.cards %></section>
  </div>
</body>
</html>
