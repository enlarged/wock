<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Wock | User Directory</title>
    <link rel="icon" type="image/png" id="favicon" href="/avatar.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #030303;
            --card-bg: rgba(10, 10, 10, 0.6);
            --border: rgba(255, 255, 255, 0.05);
            --accent: #ffffff;
            --text-main: #eeeeee;
            --text-dim: #666666;
            --font-mono: 'JetBrains Mono', monospace;
            --blue-glow: #3b82f6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        body { background-color: var(--bg-deep); font-family: 'Inter', sans-serif; color: var(--text-main); display: flex; height: 100vh; overflow: hidden; position: relative; }

        /* --- Galaxy Background --- */
        body::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle at center, #0e0e15 0%, #050508 40%, #030303 100%);
            z-index: -2; animation: swirl 30s linear infinite;
        }
        @keyframes swirl { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* --- Navigation --- */
        .nav-container { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 3000; }
        .dropdown { position: relative; padding-bottom: 15px; }
        .dropbtn {
            background: rgba(10, 10, 10, 0.95); backdrop-filter: blur(12px); border: 1px solid var(--border);
            padding: 10px 18px; border-radius: 100px; color: #fff; display: flex; align-items: center; gap: 12px; cursor: pointer;
        }
        .dropbtn img { width: 20px; height: 20px; border-radius: 50%; }
        .dropdown-content {
            display: none; position: absolute; top: 50px; left: 50%; transform: translateX(-50%);
            background: #0a0a0a; border: 1px solid var(--border); min-width: 220px; border-radius: 14px; padding: 8px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.8);
        }
        .dropdown:hover .dropdown-content { display: block; }
        .dropdown-content a { 
            color: var(--text-dim); padding: 12px 14px; text-decoration: none; display: flex; 
            align-items: center; gap: 12px; font-size: 13px; border-radius: 10px; transition: 0.2s;
        }
        .dropdown-content a:hover { background: rgba(255,255,255,0.04); color: #fff; }

        /* --- Main Layout --- */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; z-index: 10; max-width: 1400px; margin: 0 auto; width: 100%; }
        
        .content-header { padding: 120px 40px 40px; display: flex; justify-content: space-between; align-items: flex-end; }
        .title-area h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -1.5px; margin-bottom: 8px; }
        
        /* Blue text with glowing dot */
        .status-subtitle { 
            display: flex; 
            align-items: center; 
            gap: 8px; 
            color: var(--blue-glow); 
            font-size: 14px; 
            font-weight: 600; 
            text-transform: uppercase; 
            letter-spacing: 0.5px;
        }
        .glow-dot {
            width: 6px;
            height: 6px;
            background-color: var(--blue-glow);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--blue-glow), 0 0 20px var(--blue-glow);
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { opacity: 0.4; }
            50% { opacity: 1; }
            100% { opacity: 0.4; }
        }

        .search-box {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px;
            padding: 12px 18px; display: flex; align-items: center; gap: 12px; width: 340px;
        }
        .search-box input { background: none; border: none; color: #fff; font-size: 14px; outline: none; width: 100%; }

        /* --- Grid & Cards --- */
        .scroll-area { flex: 1; overflow-y: auto; padding: 0 40px 20px; scroll-behavior: smooth; }
        .user-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }

        .user-card {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 18px;
            padding: 30px 20px; transition: 0.3s; text-decoration: none; text-align: center;
            display: flex; flex-direction: column; align-items: center; backdrop-filter: blur(5px);
        }
        .user-card:hover { border-color: rgba(255,255,255,0.1); transform: translateY(-3px); background: rgba(255,255,255,0.02); }
        .user-card img { width: 90px; height: 90px; border-radius: 50%; object-fit: cover; margin-bottom: 18px; border: 2px solid var(--border); }
        .username { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 5px; }
        .userId { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); background: rgba(0,0,0,0.3); padding: 4px 10px; border-radius: 6px; margin-bottom: 15px; }
        .record-badge { font-size: 10px; font-weight: 800; text-transform: uppercase; color: #fff; background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 100px; border: 1px solid var(--border); }

        /* --- Pagination --- */
        .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; padding: 50px 0 80px; width: 100%; }
        .page-btn {
            background: var(--card-bg); border: 1px solid var(--border); color: var(--text-dim);
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            border-radius: 10px; cursor: pointer; font-size: 13px; font-weight: 600; transition: 0.2s;
            text-decoration: none;
        }
        .page-btn:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .page-btn.active { background: #fff; color: #000; border-color: #fff; }

        @media (max-width: 800px) { .content-header { flex-direction: column; align-items: flex-start; gap: 20px; } .search-box { width: 100%; } }
    </style>
</head>
<body>

    <nav class="nav-container">
        <div class="dropdown">
            <div class="dropbtn">
                <img src="https://wock.best/assets/logo.png" alt="">
                <span>Directory</span>
                <i class="fas fa-chevron-down" style="font-size: 10px; opacity: 0.3;"></i>
            </div>
            <div class="dropdown-content">
                <a href="/"><i class="fas fa-home"></i> Home</a>
                <a href="/commands"><i class="fas fa-bolt"></i> Commands</a>
                <a href="/status"><i class="fas fa-signal"></i> Status</a>
                <a href="/avatars" class="active"><i class="fas fa-address-book"></i> Directory</a>
                <a href="/profiles"><i class="fas fa-user-circle"></i> Profiles</a>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <header class="content-header">
            <div class="title-area">
                <h1>User Directory</h1>
                <div class="status-subtitle">
                    <div class="glow-dot"></div>
                    <span>Tracking digital identities</span>
                </div>
            </div>
            <div class="search-box">
                <i class="fas fa-search" style="color: #444; font-size: 14px;"></i>
                <input type="text" id="userSearch" placeholder="Search by name or ID...">
            </div>
        </header>

        <div class="scroll-area">
            <div class="user-grid" id="userGallery">
                <% if (typeof users !== 'undefined' && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <a href="/avatars/<%= user.userId %>" class="user-card">
                            <img src="<%= user.currentAvatar || 'https://wock.best/assets/logo.png' %>" alt="" loading="lazy">
                            <span class="username"><%= user.username || 'Unknown' %></span>
                            <span class="userId"><%= user.userId %></span>
                            <span class="record-badge"><%= user.avatarCount || 0 %> Records</span>
                        </a>
                    <% }) %>
                <% } else { %>
                    <p style="grid-column: 1/-1; text-align: center; color: var(--text-dim); padding-top: 50px;">No users found in the directory.</p>
                <% } %>
            </div>

            <div class="pagination">
                <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined') { %>
                    <% if (currentPage > 1) { %>
                        <a href="/avatars?page=<%= currentPage - 1 %>" class="page-btn"><i class="fas fa-chevron-left"></i></a>
                    <% } %>

                    <% 
                    let startPage = Math.max(1, currentPage - 2);
                    let endPage = Math.min(totalPages, startPage + 4);
                    if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                    for(let i = startPage; i <= endPage; i++) { if(i > 0) { %>
                        <a href="/avatars?page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                    <% }} %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/avatars?page=<%= currentPage + 1 %>" class="page-btn"><i class="fas fa-chevron-right"></i></a>
                    <% } %>
                <% } %>
            </div>
        </div>
    </main>

    <script>
        // Search logic
        const searchInput = document.getElementById('userSearch');
        const cards = document.querySelectorAll('.user-card');

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                card.style.display = text.includes(query) ? "flex" : "none";
            });
        });

        async function fetchBotAvatar() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if(data.avatar) document.getElementById('favicon').href = data.avatar;
            } catch(e) {}
        }
        fetchBotAvatar();
    </script>
</body>
</html>