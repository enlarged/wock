<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Wock | <%= username %></title>
    <link rel="icon" type="image/png" id="favicon" href="/avatar.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #030303;
            --sidebar-glass: rgba(10, 10, 12, 0.8);
            --card-bg: rgba(10, 10, 10, 0.6);
            --border: rgba(255, 255, 255, 0.05);
            --accent: #ffffff;
            --text-main: #eeeeee;
            --text-dim: #666666;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        
        body { 
            background-color: var(--bg-deep); 
            font-family: 'Inter', sans-serif; 
            color: var(--text-main); 
            display: flex; 
            height: 100vh; 
            overflow: hidden; 
            position: relative;
        }

        /* --- Galaxy & Swirl Background --- */
        body::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle at center, #0e0e15 0%, #050508 40%, #030303 100%);
            z-index: -2; animation: swirl 30s linear infinite;
        }
        body::after {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                radial-gradient(1px 1px at 20px 30px, #fff, rgba(0,0,0,0)), 
                radial-gradient(1.1px 1.1px at 100px 150px, #fff, rgba(0,0,0,0));
            background-size: 300px 300px; z-index: -1; opacity: 0.2; animation: stars 120s linear infinite;
        }
        @keyframes swirl { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes stars { from { background-position: 0 0; } to { background-position: 300px 600px; } }

        /* --- Nav Pill Dropdown --- */
        .nav-container { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 4000; }
        .dropdown { position: relative; padding-bottom: 15px; }
        .dropbtn {
            background: rgba(10, 10, 10, 0.95); backdrop-filter: blur(12px); border: 1px solid var(--border);
            padding: 10px 18px; border-radius: 100px; color: #fff; display: flex; align-items: center; gap: 12px; cursor: pointer;
        }
        .dropbtn img { width: 20px; height: 20px; border-radius: 50%; }
        .dropdown-content {
            display: none; position: absolute; top: 50px; left: 50%; transform: translateX(-50%);
            background: #0a0a0a; border: 1px solid var(--border); min-width: 220px; border-radius: 14px; padding: 8px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.8);
        }
        .dropdown:hover .dropdown-content { display: block; }
        .dropdown-content a { 
            color: var(--text-dim); padding: 12px 14px; text-decoration: none; display: flex; 
            align-items: center; gap: 12px; font-size: 13px; border-radius: 10px; transition: 0.2s;
        }
        .dropdown-content a:hover { background: rgba(255,255,255,0.04); color: #fff; }
        .dropdown-content a.active { color: #fff; background: rgba(255,255,255,0.02); }

        /* --- Sidebar --- */
        .sidebar {
            width: 300px; background: var(--sidebar-glass); border-right: 1px solid var(--border);
            display: flex; flex-direction: column; padding: 100px 25px 25px; flex-shrink: 0; backdrop-filter: blur(10px);
        }
        .sidebar-label { color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; font-weight: 800; }
        
        .user-meta-card { 
            background: rgba(255,255,255,0.02); border: 1px solid var(--border); 
            padding: 24px; border-radius: 20px; text-align: center; margin-bottom: 25px;
        }
        .user-meta-card img { width: 90px; height: 90px; border-radius: 50%; margin-bottom: 15px; border: 2px solid var(--border); object-fit: cover; }
        .user-meta-card h2 { font-size: 20px; font-weight: 800; letter-spacing: -0.8px; color: #fff; }
        
        .id-badge {
            background: #000; border: 1px solid var(--border); padding: 10px; border-radius: 12px;
            font-family: var(--font-mono); color: var(--text-main); font-size: 11px;
            display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; margin-top: 12px; transition: 0.2s;
        }
        .id-badge:hover { background: #080808; border-color: rgba(255,255,255,0.1); }

        .stat-mini { display: flex; justify-content: space-between; padding: 12px 5px; border-bottom: 1px solid var(--border); }
        .stat-mini label { font-size: 11px; color: var(--text-dim); font-weight: 600; }
        .stat-mini span { font-size: 11px; font-weight: 700; color: #fff; }

        /* --- Main Content --- */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; z-index: 10; }
        .content-header { padding: 100px 40px 30px; }
        .title-area h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -1.5px; }
        .title-area p { color: var(--text-dim); font-size: 15px; margin-top: 5px; }

        .scroll-area { flex: 1; overflow-y: auto; padding: 0 40px 60px; scroll-behavior: smooth; }
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }

        .avatar-card {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 24px;
            padding: 14px; transition: 0.3s; position: relative; backdrop-filter: blur(5px);
        }
        .avatar-card:hover { border-color: rgba(255,255,255,0.1); transform: translateY(-5px); background: rgba(255,255,255,0.02); }
        
        .img-wrap { width: 100%; aspect-ratio: 1/1; border-radius: 18px; overflow: hidden; margin-bottom: 16px; background: #000; border: 1px solid var(--border); }
        .img-wrap img { width: 100%; height: 100%; object-fit: cover; }

        .card-footer { display: flex; justify-content: space-between; align-items: center; padding: 0 5px 5px; }
        .meta-date .date { display: block; font-size: 14px; font-weight: 700; color: #fff; }
        .meta-date .time { font-size: 11px; color: var(--text-dim); font-family: var(--font-mono); }

        .btn-view {
            width: 38px; height: 38px; border-radius: 12px; background: rgba(255,255,255,0.03);
            display: flex; align-items: center; justify-content: center; color: var(--text-dim);
            text-decoration: none; transition: 0.2s; border: 1px solid var(--border);
        }
        .btn-view:hover { background: #fff; color: #000; border-color: #fff; }

        @media (max-width: 1100px) { .sidebar { display: none; } }
        @media (max-width: 600px) { 
            .content-header { padding: 110px 20px 20px; }
            .scroll-area { padding: 0 20px 40px; }
            .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .avatar-card { padding: 10px; border-radius: 18px; }
            .img-wrap { border-radius: 12px; }
            .meta-date .date { font-size: 12px; }
        }
    </style>
</head>
<body>

    <nav class="nav-container">
        <div class="dropdown">
            <div class="dropbtn">
                <img id="navAvatar" src="/logo.png" alt="">
                <span>Archives</span>
                <i class="fas fa-chevron-down" style="font-size: 10px; opacity: 0.3;"></i>
            </div>
            <div class="dropdown-content">
                <a href="/"><i class="fas fa-home"></i> Home</a>
                <a href="/commands"><i class="fas fa-bolt"></i> Commands</a>
                <a href="/status"><i class="fas fa-signal"></i> Status</a>
                <a href="/avatars" class="active"><i class="fas fa-address-book"></i> Directory</a>
                <a href="/profiles"><i class="fas fa-user-circle"></i> Profiles</a>
                <a href="/embed"><i class="fas fa-code"></i> Embeds</a>
                <a href="/docs"><i class="fas fa-book"></i> Docs</a>
                <a href="/gallery"><i class="fas fa-images"></i> Gallery</a>
            </div>
        </div>
    </nav>

    <aside class="sidebar">
        <div class="sidebar-label">Profile Insight</div>
        <div class="user-meta-card">
            <img src="<%= avatars[0].url %>" alt="<%= username %>">
            <h2><%= username %></h2>
            <div class="id-badge" onclick="copyId('<%= userId %>')">
                <span id="userIdText"><%= userId %></span> <i class="far fa-copy" id="copyIcon"></i>
            </div>
        </div>
        
        <div class="stat-mini">
            <label>Logs Stored</label>
            <span><%= avatars.length %></span>
        </div>
        <div class="stat-mini">
            <label>Discovery</label>
            <span><%= new Date(avatars[avatars.length - 1].changedAt).toLocaleDateString(undefined, { month: 'short', year: 'numeric' }) %></span>
        </div>

        <div style="margin-top: auto;">
            <a href="/avatars" style="text-decoration:none; color:var(--text-dim); font-size:12px; display:flex; align-items:center; gap:10px; padding:15px; background: rgba(255,255,255,0.02); border-radius:12px; border: 1px solid var(--border);">
                <i class="fas fa-chevron-left"></i> Return to Directory
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="content-header">
            <div class="title-area">
                <h1>Avatar History</h1>
                <p>Browsing preserved identity logs for <%= username %></p>
            </div>
        </header>

        <div class="scroll-area">
            <div class="gallery-grid">
                <% avatars.forEach(av => { %>
                    <div class="avatar-card">
                        <div class="img-wrap">
                            <img src="<%= av.url %>" alt="" loading="lazy">
                        </div>
                        <div class="card-footer">
                            <div class="meta-date">
                                <span class="date"><%= new Date(av.changedAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                <span class="time"><%= new Date(av.changedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
                            </div>
                            <a href="<%= av.url %>" target="_blank" class="btn-view" title="Open Original">
                                <i class="fas fa-external-link-alt" style="font-size: 12px;"></i>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </main>

    <script>
        async function fetchBotAvatar() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if(data.avatar) document.getElementById('navAvatar').src = data.avatar;
            } catch(e) {}
        }
        fetchBotAvatar();

        function copyId(id) {
            navigator.clipboard.writeText(id);
            const text = document.getElementById('userIdText');
            const icon = document.getElementById('copyIcon');
            const original = text.innerText;
            
            text.innerText = 'Copied!';
            icon.className = 'fas fa-check';
            text.parentElement.style.color = '#10b981';
            
            setTimeout(() => {
                text.innerText = original;
                icon.className = 'far fa-copy';
                text.parentElement.style.color = '';
            }, 2000);
        }
    </script>
</body>
</html>