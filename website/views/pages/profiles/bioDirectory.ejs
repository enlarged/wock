<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Wock | Bio Directory</title>
    <link rel="icon" type="image/png" id="favicon" href="/avatar.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #030303;
            --sidebar-glass: rgba(10, 10, 12, 0.8);
            --card-bg: rgba(10, 10, 10, 0.6);
            --border: rgba(255, 255, 255, 0.05);
            --accent: #ffffff;
            --text-main: #eeeeee;
            --text-dim: #666666;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-font-smoothing: antialiased; }
        
        body { 
            background-color: var(--bg-deep); 
            font-family: 'Inter', sans-serif; 
            color: var(--text-main); 
            display: flex; 
            height: 100vh; 
            overflow: hidden; 
            position: relative;
        }

        /* --- Galaxy & Swirl Background --- */
        body::before {
            content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle at center, #0e0e15 0%, #050508 40%, #030303 100%);
            z-index: -2; animation: swirl 30s linear infinite;
        }
        body::after {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                radial-gradient(1px 1px at 20px 30px, #fff, rgba(0,0,0,0)), 
                radial-gradient(1.1px 1.1px at 100px 150px, #fff, rgba(0,0,0,0));
            background-size: 300px 300px; z-index: -1; opacity: 0.2; animation: stars 120s linear infinite;
        }
        @keyframes swirl { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        @keyframes stars { from { background-position: 0 0; } to { background-position: 300px 600px; } }

        /* --- Nav Pill Dropdown --- */
        .nav-container { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 4000; }
        .dropdown { position: relative; padding-bottom: 15px; }
        .dropbtn {
            background: rgba(10, 10, 10, 0.95); backdrop-filter: blur(12px); border: 1px solid var(--border);
            padding: 10px 18px; border-radius: 100px; color: #fff; display: flex; align-items: center; gap: 12px; cursor: pointer;
        }
        .dropbtn img { width: 20px; height: 20px; border-radius: 50%; }
        .dropdown-content {
            display: none; position: absolute; top: 50px; left: 50%; transform: translateX(-50%);
            background: #0a0a0a; border: 1px solid var(--border); min-width: 220px; border-radius: 14px; padding: 8px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.8);
        }
        .dropdown:hover .dropdown-content { display: block; }
        .dropdown-content a { 
            color: var(--text-dim); padding: 12px 14px; text-decoration: none; display: flex; 
            align-items: center; gap: 12px; font-size: 13px; border-radius: 10px; transition: 0.2s;
        }
        .dropdown-content a:hover { background: rgba(255,255,255,0.04); color: #fff; }
        .dropdown-content a.active { color: #fff; background: rgba(255,255,255,0.02); }

        /* --- Sidebar --- */
        .sidebar {
            width: 280px; background: var(--sidebar-glass); border-right: 1px solid var(--border);
            display: flex; flex-direction: column; padding: 100px 20px 20px; flex-shrink: 0; backdrop-filter: blur(10px);
        }
        .sidebar-label { color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; font-weight: 800; }
        .stat-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 20px; border-radius: 16px; margin-bottom: 12px; }
        .stat-card label { display: block; font-size: 10px; color: var(--text-dim); text-transform: uppercase; margin-bottom: 5px; }
        .stat-card span { font-size: 1.4rem; font-weight: 800; color: #fff; }

        /* --- Main Content --- */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; position: relative; z-index: 10; }
        .content-header { padding: 100px 40px 30px; display: flex; justify-content: space-between; align-items: flex-end; }
        .title-area h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -1.5px; }
        .search-box {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px;
            padding: 12px 18px; display: flex; align-items: center; gap: 12px; width: 340px;
        }
        .search-box input { background: none; border: none; color: #fff; font-size: 14px; outline: none; width: 100%; }

        /* --- Profile Grid --- */
        .scroll-area { flex: 1; overflow-y: auto; padding: 0 40px 20px; scroll-behavior: smooth; }
        .user-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }

        .user-card {
            background: var(--card-bg); border: 1px solid var(--border); border-radius: 20px;
            padding: 30px 20px; transition: 0.3s; text-decoration: none; text-align: center;
            display: flex; flex-direction: column; align-items: center; backdrop-filter: blur(5px);
        }
        .user-card:hover { border-color: rgba(255,255,255,0.1); transform: translateY(-4px); background: rgba(255,255,255,0.02); }
        .user-card img { width: 90px; height: 90px; border-radius: 50%; object-fit: cover; margin-bottom: 18px; border: 2px solid var(--border); }
        
        .username { font-size: 16px; font-weight: 700; margin-bottom: 4px; display: block; }
        .display-name { font-size: 12px; color: var(--text-dim); margin-bottom: 15px; font-weight: 500; }
        
        .view-count {
            font-size: 10px; font-weight: 800; text-transform: uppercase;
            color: var(--text-dim); background: rgba(255, 255, 255, 0.05);
            padding: 5px 14px; border-radius: 100px; border: 1px solid var(--border);
            display: flex; align-items: center; gap: 8px;
        }

        /* --- Pagination --- */
        .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; padding: 30px 0 60px; }
        .page-btn {
            background: var(--card-bg); border: 1px solid var(--border); color: var(--text-dim);
            padding: 8px 16px; border-radius: 10px; cursor: pointer; font-size: 13px; font-weight: 600; transition: 0.2s;
            text-decoration: none;
        }
        .page-btn:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .page-btn.active { background: #fff; color: #000; border-color: #fff; }

        @media (max-width: 1000px) { .sidebar { display: none; } .content-header { flex-direction: column; align-items: flex-start; gap: 20px; padding-top: 120px; } .search-box { width: 100%; } }
    </style>
</head>
<body>

    <nav class="nav-container">
        <div class="dropdown">
            <div class="dropbtn">
                <img id="navAvatar" src="/logo.png" alt="">
                <span>Profiles</span>
                <i class="fas fa-chevron-down" style="font-size: 10px; opacity: 0.3;"></i>
            </div>
            <div class="dropdown-content">
                <a href="/"><i class="fas fa-home"></i> Home</a>
                <a href="/commands"><i class="fas fa-bolt"></i> Commands</a>
                <a href="/status"><i class="fas fa-signal"></i> Status</a>
                <a href="/avatars"><i class="fas fa-address-book"></i> Directory</a>
                <a href="/profiles" class="active"><i class="fas fa-user-circle"></i> Profiles</a>
                <a href="/embed"><i class="fas fa-code"></i> Embeds</a>
                <a href="/docs"><i class="fas fa-book"></i> Docs</a>
                <a href="/gallery"><i class="fas fa-images"></i> Gallery</a>
            </div>
        </div>
    </nav>

    <aside class="sidebar">
        <div class="sidebar-label">Community</div>
        <div class="stat-card">
            <label>Active Bios</label>
            <span><%= totalBios.toLocaleString() %></span>
        </div>
        <div class="stat-card">
            <label>Global Reach</label>
            <span><%= directory.reduce((acc, p) => acc + p.views, 0).toLocaleString() %> Views</span>
        </div>
        
        <div style="margin-top: auto;">
            <a href="/" style="text-decoration:none; color:var(--text-dim); font-size:12px; display:flex; align-items:center; gap:10px; padding:15px; background: rgba(255,255,255,0.02); border-radius:12px; border: 1px solid var(--border);">
                <i class="fas fa-plus"></i> Create Profile
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="content-header">
            <div class="title-area">
                <h1>Bio Directory</h1>
                <p style="color:var(--text-dim); font-size: 14px; margin-top: 5px;">Explore custom identities created on wock.best</p>
            </div>
            <div class="search-box">
                <i class="fas fa-search" style="color: #444; font-size: 14px;"></i>
                <input type="text" id="bioSearch" placeholder="Search by name..." onkeyup="filterBios()">
            </div>
        </header>

        <div class="scroll-area">
            <div class="user-grid" id="bioGallery">
                <% directory.forEach(profile => { %>
                    <a href="/@<%= profile.username %>" class="user-card" data-name="<%= profile.username.toLowerCase() %>">
                        <img src="<%= profile.avatar %>" alt="" loading="lazy">
                        <span class="username" style="color: <%= profile.color %>;">@<%= profile.username %></span>
                        <span class="display-name"><%= profile.displayName %></span>
                        <div class="view-count">
                            <i class="far fa-eye" style="font-size: 10px;"></i> <%= profile.views.toLocaleString() %>
                        </div>
                    </a>
                <% }) %>
            </div>

            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="/profiles?page=<%= currentPage - 1 %>" class="page-btn"><i class="fas fa-chevron-left"></i></a>
                <% } %>

                <% 
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                
                for(let i = startPage; i <= endPage; i++) { %>
                    <a href="/profiles?page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                <% } %>

                <% if (currentPage < totalPages) { %>
                    <a href="/profiles?page=<%= currentPage + 1 %>" class="page-btn"><i class="fas fa-chevron-right"></i></a>
                <% } %>
            </div>
        </div>
    </main>

    <script>
        async function fetchBotAvatar() {
            try {
                const res = await fetch('/api/stats');
                const data = await res.json();
                if(data.avatar) {
                    document.getElementById('favicon').href = data.avatar;
                    document.getElementById('navAvatar').src = data.avatar;
                }
            } catch(e) {}
        }
        fetchBotAvatar();

        function filterBios() {
            const input = document.getElementById('bioSearch').value.toLowerCase();
            const cards = document.querySelectorAll('.user-card');
            cards.forEach(card => {
                const name = card.getAttribute('data-name');
                card.style.display = name.includes(input) ? "flex" : "none";
            });
        }
    </script>
</body>
</html>