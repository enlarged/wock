            </a>

            <nav class="site-nav" aria-label="Main navigation">
                <a href="/">Home</a>
                <a href="/commands">Commands</a>
                <a href="/api" class="active">API</a>
                <a href="/docs">Docs</a>
                <a href="/status">Status</a>
                <a href="/updates">Updates</a>
                <a href="/gallery">Gallery</a>
            </nav>

            <div class="page-pill">
                <i class="fas fa-code"></i>
