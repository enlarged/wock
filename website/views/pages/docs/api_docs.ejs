            <div class="footer-col">
                <h4>Support</h4>
                <a href="/docs">Documentation</a>
                <a href="https://discord.gg/wockbot" target="_blank" rel="noopener">Support Server</a>
                <a href="/privacy">Privacy Policy</a>
